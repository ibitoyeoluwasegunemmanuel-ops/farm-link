{
  "expo": {
    "name": "FarmLink",
    "slug": "farmlink",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2318"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.farmlink.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FarmLink uses your camera to scan crops and upload product images.",
        "NSPhotoLibraryUsageDescription": "FarmLink accesses your photos to upload product images.",
        "NSLocationWhenInUseUsageDescription": "FarmLink uses your location for delivery tracking and finding nearby farmers.",
        "NSMicrophoneUsageDescription": "FarmLink uses your microphone for voice messages and AI assistant."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D2318"
      },
      "package": "com.farmlink.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        { "cameraPermission": "Allow FarmLink to access your camera." }
      ],
      [
        "expo-location",
        { "locationWhenInUsePermission": "Allow FarmLink to use your location." }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1B5E20"
        }
      ]
    ],
    "scheme": "farmlink",
    "experiments": {
      "typedRoutes": true
    }
  }
}
